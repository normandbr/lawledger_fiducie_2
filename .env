# ── LawLedger Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# On Windows (PowerShell):
#   Copy-Item .env.example .env
#   notepad .env
# On Linux/macOS:
#   cp .env.example .env
#   nano .env

# ── Database (SQL Server / MSSQL) ─────────────────────────────────────────────
DB_SERVER=hypervwin10\testing
DB_NAME=LawLedger
DB_USER=SA
DB_PASSWORD=bran5965

# Optional: override the ODBC driver name (default: ODBC Driver 17 for SQL Server)
# DB_DRIVER=ODBC Driver 18 for SQL Server

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a strong secret key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=8513c25c36b9708695e2fc52da2ba23df65839164c5d19fcefd5ea0dc565896f
# ── Server ────────────────────────────────────────────────────────────────────
HOST=192.168.0.26
PORT=5000
